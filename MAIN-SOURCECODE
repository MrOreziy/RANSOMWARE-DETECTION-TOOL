            handlers=[
                logging.FileHandler('ransomware_detector.log'),
                logging.StreamHandler(sys.stdout)
            ]
        )
    
    def raise_alert(self, alert_type: str, message: str, severity: str = "MEDIUM"):
        """Log and store security alerts."""
        alert = {
            "timestamp": datetime.now().isoformat(),
            "type": alert_type,
            "severity": severity,
            "message": message
        }
        self.alerts_log.append(alert)
        
        log_func = logging.critical if severity == "CRITICAL" else logging.warning if severity == "HIGH" else logging.warning
        log_func(f"[{alert_type}] {message}")
        
        # Write to alert log file
        with open("alerts.json", "a") as f:
            f.write(json.dumps(alert) + "\n")
        
        # Optional: trigger quarantine
        if severity in ["HIGH", "CRITICAL"]:
            self._auto_quarantine(message)
    
    def _auto_quarantine(self, alert_message: str):
        """Basic quarantine suggestion/log."""
        logging.info(f"Auto-quarantine triggered by: {alert_message}")
        # In production, you'd implement actual file quarantine here
    
    def start_monitoring(self, directory: str):
        """Start real-time filesystem monitoring."""
        if not WATCHDOG_AVAILABLE:
            logging.error("Cannot start monitoring: 'watchdog' library not installed.")
            return False
        
        self.protect_dir = Path(directory)
        if not self.protect_dir.exists():
            logging.error(f"Directory does not exist: {directory}")
            return False
        
        # Deploy honeypots
        self.honeypot = HoneypotManager(directory, self.config)
        deployed = self.honeypot.deploy_honeypots()
        logging.info(f"Deployed {len(deployed)} honeypot files")
        
        # Setup event handler
        event_handler = RansomwareEventHandler(self.config, self)
        self.observer = Observer()
        self.observer.schedule(event_handler, str(directory), recursive=True)
        self.observer.start()
        self.running = True
        
        # Start burst monitoring thread
        self.burst_check_thread = threading.Thread(target=self._burst_monitor_loop, args=(event_handler,), daemon=True)
        self.burst_check_thread.start()
        
        # Start process monitoring thread (optional)
        if PSUTIL_AVAILABLE:
            self.process_monitor_thread = threading.Thread(target=self._process_monitor_loop, daemon=True)
            self.process_monitor_thread.start()
        
        logging.info(f"Real-time monitoring started on: {directory}")
        print(f"✓ Monitoring active on {directory}")
        print("Press Ctrl+C to stop...")
        
        try:
            while self.running:
                time.sleep(1)
        except KeyboardInterrupt:
            self.stop_monitoring()
        
        return True
    
    def _burst_monitor_loop(self, event_handler: RansomwareEventHandler):
        """Periodically check for burst activity."""
        while self.running:
            time.sleep(5)
            try:
                event_handler.check_burst_activity()
            except Exception as e:
                logging.error(f"Burst monitor error: {e}")
    
    def _process_monitor_loop(self):
        """Monitor running processes for ransomware indicators."""
        while self.running:
            suspicious = ProcessDetector.scan_running_processes()
            if suspicious:
                self.raise_alert(
                    "SUSPICIOUS_PROCESS",
                    f"Suspicious processes detected: {', '.join(suspicious)}",
                    "HIGH"
                )
            time.sleep(30)  # Scan every 30 seconds
    
    def stop_monitoring(self):
        """Stop all monitoring activities."""
        self.running = False
        if self.observer:
            self.observer.stop()
            self.observer.join()
        logging.info("Monitoring stopped.")
        print("\nMonitoring stopped.")
    
    def run_scan(self, directory: str, recursive: bool = True) -> List[Dict]:
        """Perform on-demand security scan."""
        print(f"\n[*] Scanning {directory} for ransomware indicators...")
        alerts = self.scanner.scan_directory(directory, recursive)
        
        if alerts:
            print(f"\n[!] Found {len(alerts)} potential threats:")
            for alert in alerts:
                print(f"  - [{alert['severity']}] {alert['message']} (File: {alert['file']})")
                self.raise_alert(alert['type'], alert['message'], alert['severity'])
        else:
            print("[✓] No ransomware indicators found.")
        
        return alerts
    
    def generate_report(self) -> str:
        """Generate JSON report of all alerts."""
        report = {
            "generated": datetime.now().isoformat(),
            "tool_signature": "{orezziy}",
            "total_alerts": len(self.alerts_log),
            "alerts": self.alerts_log,
            "config": self.config
        }
        
        with open("detection_report.json", "w") as f:
            json.dump(report, f, indent=2)
        
        return "detection_report.json"

# ========== CLI Interface ==========
def main():
    parser = argparse.ArgumentParser(
        description="Ransomware Detection Tool - Professional Behavioral Analysis",
        epilog="Signature: {orezziy} - GitHub: https://github.com/orezziy/ransomware-detector"
    )
    
    parser.add_argument("--monitor", "-m", type=str, help="Directory to monitor in real-time")
    parser.add_argument("--scan", "-s", type=str, help="Directory to scan on-demand")
    parser.add_argument("--generate-honeypots", "-g", type=str, help="Generate honeypot files in specified directory")
    parser.add_argument("--config", "-c", type=str, help="JSON configuration file")
    parser.add_argument("--report", "-r", action="store_true", help="Generate report after scan/monitor")
    parser.add_argument("--threshold", "-t", type=float, default=7.5, help="Entropy threshold (default: 7.5)")
    parser.add_argument("--verbose", "-v", action="store_true", help="Enable verbose output")
    
    args = parser.parse_args()
    
    # Load custom config if provided
    config = DEFAULT_CONFIG.copy()
    if args.config:
        try:
            with open(args.config, 'r') as f:
                user_config = json.load(f)
                config.update(user_config)
        except Exception as e:
            print(f"Error loading config: {e}")
    
    if args.threshold:
        config["entropy_threshold"] = args.threshold
    
    # Initialize detector
    detector = RansomwareDetector(config)
    
    # Handle generate honeypots only
    if args.generate_honeypots:
        honeypot = HoneypotManager(args.generate_honeypots, config)
        deployed = honeypot.deploy_honeypots()
        print(f"Deployed {len(deployed)} honeypot files in {args.generate_honeypots}")
        return 0
    
    # Handle monitoring mode
    if args.monitor:
        detector.start_monitoring(args.monitor)
        if args.report:
            report_file = detector.generate_report()
            print(f"\nReport generated: {report_file}")
        return 0
    
    # Handle scan mode
    if args.scan:
        alerts = detector.run_scan(args.scan)
        if args.report:
            report_file = detector.generate_report()
            print(f"\nReport generated: {report_file}")
        return 0
    
    # No arguments - show help
    parser.print_help()
    print("\nExample usage:")
    print("  python ransomware_detector.py --scan /home/user/documents")
    print("  python ransomware_detector.py --monitor /home/user/documents")
    print("  python ransomware_detector.py --generate-honeypots /home/user/documents")
    return 1

if __name__ == "__main__":
    sys.exit(main())
