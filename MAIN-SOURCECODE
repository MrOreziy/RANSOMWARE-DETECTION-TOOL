# ========== Entropy Calculation ==========
def calculate_shannon_entropy(data: bytes, sample_limit: int = 1024 * 1024) -> float:
    """
    Calculate Shannon entropy of binary data.
    High entropy (close to 8) indicates randomness typical of encrypted content.
    """
    if not data:
        return 0.0
    
    # Sample first N bytes for large files for performance
    if len(data) > sample_limit:
        data = data[:sample_limit]
    
    byte_counts = defaultdict(int)
    for byte in data:
        byte_counts[byte] += 1
    
    entropy = 0.0
    length = len(data)
    for count in byte_counts.values():
        probability = count / length
        entropy -= probability * math.log2(probability)
    
    return entropy

def file_entropy(filepath: str, max_size_mb: int = 100) -> Optional[float]:
    """Calculate entropy of a file's contents."""
    try:
        file_size = os.path.getsize(filepath)
        if file_size > max_size_mb * 1024 * 1024:
            return None
        
        with open(filepath, 'rb') as f:
            data = f.read()
            return calculate_shannon_entropy(data)
    except (IOError, OSError):
        return None

# ========== Suspicious Process Detection ==========
class ProcessDetector:
    """Detect known ransomware processes and anomalies."""
    
    # Known ransomware process names (case-insensitive)
    SUSPICIOUS_PROCESSES = {
        "wannacry", "locky", "cryptolocker", "badrabbit", "petya", "notpetya",
        "ryuk", "phobos", "globelmposter", "cerber", "xvpn", "taskmgr.exe"  # some masquerade
    }
    
    @staticmethod
    def scan_running_processes() -> List[str]:
        """Return list of suspicious running processes."""
        if not PSUTIL_AVAILABLE:
            return []
        
        suspicious = []
        try:
            for proc in psutil.process_iter(['name', 'pid']):
                try:
                    proc_name = proc.info['name'].lower()
                    for susp in ProcessDetector.SUSPICIOUS_PROCESSES:
                        if susp in proc_name:
                            suspicious.append(f"{proc.info['name']} (PID: {proc.info['pid']})")
                            break
                except (psutil.NoSuchProcess, psutil.AccessDenied):
                    continue
        except Exception as e:
            logging.error(f"Process scan error: {e}")
        
        return suspicious

# ========== Honeypot Manager ==========
class HoneypotManager:
    """Create and manage decoy files to detect ransomware tampering."""
    
    def __init__(self, protect_dir: str, config: dict):
        self.protect_dir = Path(protect_dir)
        self.config = config
        self.honeypot_files: Set[Path] = set()
        self.honeypot_content = "DECOY_FILE_RANSOMWARE_DETECTION_{orezziy}_SENSITIVE_DATA"
    
    def deploy_honeypots(self) -> List[Path]:
        """Create honeypot files in protected directory."""
        deployed = []
        for name in self.config.get("honeypot_names", []):
            hp_path = self.protect_dir / name
            if not hp_path.exists():
                try:
                    with open(hp_path, 'w') as f:
                        f.write(self.honeypot_content)
                    deployed.append(hp_path)
                    self.honeypot_files.add(hp_path)
                    logging.info(f"Honeypot deployed: {hp_path}")
                except Exception as e:
                    logging.error(f"Failed to deploy honeypot {hp_path}: {e}")
        return deployed
    
    def is_honeypot(self, filepath: str) -> bool:
        """Check if file is a known honeypot."""
        return Path(filepath) in self.honeypot_files
    
    def check_honeypot_integrity(self) -> List[str]:
        """Check if any honeypot files were modified."""
        altered = []
        for hp in self.honeypot_files:
            if hp.exists():
                try:
                    with open(hp, 'r') as f:
                        content = f.read()
                        if self.honeypot_content not in content:
                            altered.append(str(hp))
                except Exception:
                    altered.append(str(hp))
            else:
                altered.append(str(hp))  # File missing = deleted
        return altered

# ========== File Scanner (On-Demand) ==========
class RansomwareScanner:
    """Scan directories for signs of ransomware encryption."""
    
    def __init__(self, config: dict):
        self.config = config
        self.alerts = []
    
    def scan_directory(self, directory: str, recursive: bool = True) -> List[Dict]:
        """
        Scan directory for suspicious files.
        Returns list of alerts with details.
        """
        alerts = []
        path = Path(directory)
        
        if not path.exists():
            logging.error(f"Directory not found: {directory}")
            return alerts
        
        # Scan for ransomware notes
        for note_pattern in self.config["ransomware_notes"]:
            for note_file in path.rglob(f"*{note_pattern}*"):
                if note_file.is_file():
                    alerts.append({
                        "type": "ransomware_note",
                        "file": str(note_file),
                        "severity": "HIGH",
                        "message": f"Ransomware note detected: {note_file.name}"
                    })
        
        # Scan for suspicious extensions
        suspicious_exts = self.config["suspicious_extensions"]
        for ext in suspicious_exts:
            for file_path in path.rglob(f"*{ext}"):
                if file_path.is_file():
                    alerts.append({
                        "type": "suspicious_extension",
                        "file": str(file_path),
                        "severity": "HIGH",
                        "message": f"File with ransomware extension: {file_path.name}"
                    })
        
        # Entropy-based detection
        for file_path in path.rglob("*"):
            if not file_path.is_file():
                continue
            
            # Skip excluded directories
            if any(excl in str(file_path) for excl in self.config["excluded_dirs"]):
                continue
            
            # Only check monitored file types
            if file_path.suffix.lower() not in self.config["monitored_extensions"]:
                continue
            
            entropy = file_entropy(str(file_path), self.config["max_file_size_mb"])
            if entropy and entropy > self.config["entropy_threshold"]:
                alerts.append({
                    "type": "high_entropy",
                    "file": str(file_path),
                    "severity": "MEDIUM",
                    "entropy": round(entropy, 2),
                    "message": f"High entropy detected (potential encryption): {entropy:.2f}"
                })
        
        return alerts

# ========== Real-time Monitor (watchdog) ==========
class RansomwareEventHandler(FileSystemEventHandler):
    """Handle filesystem events and detect ransomware behavior."""
    
    def __init__(self, config: dict, detector_instance):
        self.config = config
        self.detector = detector_instance
        self.event_queue = deque(maxlen=1000)
        self.event_timestamps = deque(maxlen=500)
        self.file_rename_map = {}
        
    def on_created(self, event):
        if not event.is_directory:
            self._handle_event(event.src_path, "created")
    
    def on_modified(self, event):
        if not event.is_directory:
            self._handle_event(event.src_path, "modified")
    
    def on_moved(self, event):
        if not event.is_directory:
            self._handle_event(event.dest_path, "moved", src_path=event.src_path)
    
    def _handle_event(self, filepath: str, event_type: str, src_path: str = None):
        """Process single filesystem event."""
        # Track event for burst detection
        self.event_timestamps.append(time.time())
        
        # Check if it's a honeypot
        if hasattr(self.detector, 'honeypot') and self.detector.honeypot.is_honeypot(filepath):
            self.detector.raise_alert(
                "HONEYPOT_ACCESS",
                f"Honeypot file accessed/modified: {filepath}",
                "CRITICAL"
            )
        
        # Check for ransomware notes
        filename = os.path.basename(filepath)
        for note in self.config["ransomware_notes"]:
            if note.lower() in filename.lower():
                self.detector.raise_alert(
                    "RANSOMWARE_NOTE",
                    f"Ransomware note created: {filename} at {filepath}",
                    "HIGH"
                )
        
        # Check for suspicious extension changes
        if event_type == "moved" and src_path:
            old_ext = os.path.splitext(src_path)[1].lower()
            new_ext = os.path.splitext(filepath)[1].lower()
            if new_ext in self.config["suspicious_extensions"]:
                self.detector.raise_alert(
                    "EXTENSION_CHANGE",
                    f"File renamed to suspicious extension: {src_path} -> {filepath}",
                    "HIGH"
                )
        
        # Check new file extension directly
        ext = os.path.splitext(filepath)[1].lower()
        if ext in self.config["suspicious_extensions"]:
            self.detector.raise_alert(
                "SUSPICIOUS_EXTENSION",
                f"Suspicious extension created: {filename} ({ext})",
                "HIGH"
            )
    
    def check_burst_activity(self):
        """Detect mass file modifications (ransomware behavior)."""
        current_time = time.time()
        window_start = current_time - self.config["burst_window_seconds"]
        
        # Count events in time window
        event_count = sum(1 for ts in self.event_timestamps if ts >= window_start)
        
        if event_count > self.config["burst_threshold"]:
            self.detector.raise_alert(
                "BURST_ACTIVITY",
                f"Mass file changes detected: {event_count} changes in {self.config['burst_window_seconds']} seconds",
                "CRITICAL"
            )
            self.event_timestamps.clear()  # Avoid repeated alerts

